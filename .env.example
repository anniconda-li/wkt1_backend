# ====== DashScope 通用配置 ======
DASHSCOPE_API_KEY=your_dashscope_api_key

# ====== TTS 语音合成 ======
TTS_PROVIDER=dashscope
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry

# ====== ASR 语音识别 ======
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-realtime-v2

# ====== 视觉识别 ======
VISION_PROVIDER=dashscope
VISION_MODEL=qwen-vl-plus
CAMERA_UPLOAD_TIMEOUT=25

# ====== 百炼（阿里云 AI）应用 ======
BAILIAN_API_KEY=your_bailian_api_key
# 只保留一个问答应用：用于把本地文物卡片组织成语音导游回答
BAILIAN_QA_APP_ID=your_bailian_qa_app_id
BAILIAN_APP_BASE_URL=https://dashscope.aliyuncs.com
BAILIAN_TIMEOUT=60

# ====== 本地文物匹配和知识卡片 ======
VISION_CANDIDATES_PATH=knowledge/config/museum_vision_candidates.json
VISION_PROFILES_PATH=knowledge/config/vision_profiles.json
EXHIBIT_KNOWLEDGE_PATH=knowledge/config/exhibit_cards.json
VISUAL_MATCH_MIN_CONFIDENCE=0.42
VISUAL_MATCH_ACCEPT_CONFIDENCE=0.60
VISUAL_MATCH_MIN_MARGIN=0.08
VISUAL_MATCH_SCORE_NORMALIZER=1.20

# ====== 扩展功能 ======
AUTO_TTS_BACKGROUND=true
ENABLE_DEBUG_ROUTES=false

# ====== UDP 对讲下行编码 ======
# pcm: 兼容旧设备，原样下发 APP_INTERCOM_PKT_AUDIO=4
# opus: 服务端把上行 640B PCM 编码为 raw Opus，下发 APP_INTERCOM_PKT_AUDIO_OPUS=7
INTERCOM_DOWNLINK_CODEC=pcm
INTERCOM_OPUS_BITRATE=20000
INTERCOM_OPUS_COMPLEXITY=3
# 音频热路径日志限频：50 表示每路每 50 帧约 1 秒打印一次；0 表示关闭音频帧日志
INTERCOM_AUDIO_LOG_EVERY_N=50

# ====== 外部工具 ======
FFMPEG_BIN=ffmpeg
